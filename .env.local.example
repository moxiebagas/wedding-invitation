# Supabase — public keys, safe to expose to the browser.
# Find these in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Admin "blast undangan" (/admin/blast) — server-only, never sent to the browser.
# service_role key: Supabase dashboard → Settings → API → service_role (secret).
# It bypasses Row Level Security, so it must never be prefixed NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
# Random secret that signs the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=generate-a-random-secret

# The actual admin login (username/password) lives in the `admin_users` table,
# not in an env var. Set/update it with:
#   node scripts/set-admin-user.mjs <username> <password>
